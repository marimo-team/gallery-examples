&gt;&lt;/span&gt;&quot;' data-start='0.01' data-stop='1.0' data-step='0.01' data-steps='[]' data-debounce='false' data-disabled='false' data-orientation='&quot;horizontal&quot;' data-show-value='false' data-include-input='false' data-full-width='false'></marimo-slider></marimo-ui-element></li>\n<li><marimo-ui-element object-id='MJUe-29' random-id='fd70ac67-088a-072b-d76b-4888e6579940'><marimo-slider data-initial-value='40' data-label='&quot;&lt;span class=&#92;&quot;markdown prose dark:prose-invert contents&#92;&quot;&gt;&lt;span class=&#92;&quot;paragraph&#92;&quot;&gt;Grid resolution&lt;/span&gt;&lt;/span&gt;&quot;' data-start='20' data-stop='80' data-step='5' data-steps='[]' data-debounce='false' data-disabled='false' data-orientation='&quot;horizontal&quot;' data-show-value='false' data-include-input='false' data-full-width='false'></marimo-slider></marimo-ui-element></li>\n<li><marimo-ui-element object-id='MJUe-30' random-id='c571e619-eea6-6a63-71ca-d9ae67c05e4e'><marimo-slider data-initial-value='1.5' data-label='&quot;&lt;span class=&#92;&quot;markdown prose dark:prose-invert contents&#92;&quot;&gt;&lt;span class=&#92;&quot;paragraph&#92;&quot;&gt;Loss cap&lt;/span&gt;&lt;/span&gt;&quot;' data-start='0.5' data-stop='5.0' data-step='0.25' data-steps='[]' data-debounce='false' data-disabled='false' data-orientation='&quot;horizontal&quot;' data-show-value='false' data-include-input='false' data-full-width='false'></marimo-slider></marimo-ui-element></li>\n</ul></span></marimo-dict></marimo-ui-element></marimo-form></marimo-ui-element>"
