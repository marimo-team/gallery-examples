      "outputs": [
        {
          "type": "data",
          "data": {
            "text/html": "<div style='display: flex;flex: 1;flex-direction: row;justify-content: space-between;align-items: normal;flex-wrap: nowrap;gap: 0.5rem'><div style='display: flex;flex: 1;flex-direction: column;justify-content: flex-start;align-items: normal;flex-wrap: nowrap;gap: 0.5rem'><marimo-ui-element object-id='MJUe-0' random-id='69f2a4dc-661c-242f-7775-910b795fc566'><marimo-text data-initial-value='&quot;(x-1)(x+1)(x**2-2)&quot;' data-label='&quot;&#92;u003cspan class=&#92;&quot;markdown prose dark:prose-invert contents&#92;&quot;&#92;u003e&#92;u003cspan class=&#92;&quot;paragraph&#92;&quot;&#92;u003eExpression&#92;u003c/span&#92;u003e&#92;u003c/span&#92;u003e&quot;' data-placeholder='&quot;&quot;' data-kind='&quot;text&quot;' data-full-width='true' data-disabled='false' data-debounce='true'></marimo-text></marimo-ui-element><span class=\"markdown prose dark:prose-invert contents\"><table>\n<thead>\n<tr>\n<th style=\"text-align: left;\">Operation</th>\n<th style=\"text-align: left;\">Result</th>\n</tr>\n</thead>\n<tbody>\n<tr>\n<td style=\"text-align: left;\"><strong>Simplified</strong></td>\n<td style=\"text-align: left;\"><marimo-tex class=\"arithmatex\">||(\\,x^{4} - 3 x^{2} + 2\\,||)</marimo-tex></td>\n</tr>\n<tr>\n<td style=\"text-align: left;\"><strong>Factored</strong></td>\n<td style=\"text-align: left;\"><marimo-tex class=\"arithmatex\">||(\\,\\left(x - 1\\right) \\left(x + 1\\right) \\left(x^{2} - 2\\right)\\,||)</marimo-tex></td>\n</tr>\n<tr>\n<td style=\"text-align: left;\"><strong>Expanded</strong></td>\n<td style=\"text-align: left;\"><marimo-tex class=\"arithmatex\">||(\\,x^{4} - 3 x^{2} + 2\\,||)</marimo-tex></td>\n</tr>\n<tr>\n<td style=\"text-align: left;\"><strong>Roots ( = 0)</strong></td>\n<td style=\"text-align: left;\"><marimo-tex class=\"arithmatex\">||(\\,x = -1\\,||)</marimo-tex>, <marimo-tex class=\"arithmatex\">||(\\,x = 1\\,||)</marimo-tex>, <marimo-tex class=\"arithmatex\">||(\\,x = - \\sqrt{2}\\,||)</marimo-tex>, <marimo-tex class=\"arithmatex\">||(\\,x = \\sqrt{2}\\,||)</marimo-tex></td>\n</tr>\n<tr>\n<td style=\"text-align: left;\"><strong>Derivative (d/dx)</strong></td>\n<td style=\"text-align: left;\"><marimo-tex class=\"arithmatex\">||(\\,2 x \\left(x - 1\\right) \\left(x + 1\\right) + \\left(x - 1\\right) \\left(x^{2} - 2\\right) + \\left(x + 1\\right) \\left(x^{2} - 2\\right)\\,||)</marimo-tex></td>\n</tr>\n<tr>\n<td style=\"text-align: left;\"><strong>Integral (dx)</strong></td>\n<td style=\"text-align: left;\"><marimo-tex class=\"arithmatex\">||(\\,\\frac{x^{5}}{5} - x^{3} + 2 x\\,||)</marimo-tex></td>\n</tr>\n<tr>\n<td style=\"text-align: left;\"><strong>Series (x \u2192 0)</strong></td>\n<td style=\"text-align: left;\"><marimo-tex class=\"arithmatex\">||(\\,x^{4} - 3 x^{2} + 2\\,||)</marimo-tex></td>\n</tr>\n</tbody>\n</table></span></div><div style='display: flex;flex: 1;flex-direction: column;justify-content: flex-start;align-items: normal;flex-wrap: nowrap;gap: 0.5rem'><br/><br/><marimo-mime-renderer data-mime='&quot;application/vnd.marimo+mimebundle&quot;' data-data='&quot;{&#92;&quot;image/png&#92;&quot;: &#92;&quot;data:image/png;base64,&#92;&quot;, &#92;&quot;__metadata__&#92;&quot;: {&#92;&quot;image/png&#92;&quot;: {&#92;&quot;width&#92;&quot;: 531, &#92;&quot;height&#92;&quot;: 359}}}&quot;'></marimo-mime-renderer></div></div>"
